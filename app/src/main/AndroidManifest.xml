<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬
         忙聽赂氓驴聝忙卢聤茅聶聬
    芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬 -->

    <!-- 忙聡赂忙碌庐猫娄聳莽陋聴 芒聙聰 猫庐聯茅聸路茅聹聠茅隆炉莽陇潞氓聹篓忙聣聙忙聹聣 App 盲鹿聥盲赂聤 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 莽露虏莽碌隆 芒聙聰 茅聙拢忙聨楼氓庐露莽聰篓盲录潞忙聹聧氓聶篓 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 氓聣聧氓聫掳忙聹聧氓聥聶 芒聙聰 莽垄潞盲驴聺茅聸路茅聹聠忙聦聛莽潞聦氓聹篓氓戮聦氓聫掳茅聛聥猫隆聦 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- 茅聳聥忙漏聼猫聡陋氓聥聲氓聲聼氓聥聲 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 茅聸禄茅聡聫莽聥聙忙聟聥忙聞聼莽聼楼 -->
    <uses-permission android:name="android.permission.BATTERY_STATS" />

    <!-- 茅聹聡氓聥聲氓聫聧茅楼聥 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- 芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬
         Note: 盲禄楼盲赂聥氓聟漏茅聽聟茅聹聙莽聰篓忙聢露氓聹篓莽鲁禄莽碌卤猫篓颅氓庐職忙聣聥氓聥聲茅聳聥氓聲聼
         - Accessibility Service (莽聞隆茅職聹莽陇聶忙聹聧氓聥聶)
         - Notification Listener Service
    芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬芒聲聬 -->

    <application
        android:name=".CyberNaviApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CyberNavi"
        android:requestLegacyExternalStorage="false">

        <!-- 芒聰聙芒聰聙 盲赂禄 Activity茂录聢猫篓颅氓庐職茅聽聛茅聺垄茂录聣芒聰聙芒聰聙 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CyberNavi">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 芒聰聙芒聰聙 忙聡赂忙碌庐猫娄聳莽陋聴忙聹聧氓聥聶 芒聰聙芒聰聙 -->
        <service
            android:name=".service.FloatingWindowService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:label="@string/floating_service_label">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="茅聸路茅聹聠 AI 茅聽聵猫聢陋氓聯隆忙聡赂忙碌庐猫娄聳莽陋聴" />
        </service>

        <!-- 芒聰聙芒聰聙 Accessibility Service 芒聙聰 莽鲁禄莽碌卤 AI 猫录赂氓聡潞忙聢陋莽聧虏 芒聰聙芒聰聙 -->
        <service
            android:name=".service.ThunderAccessibilityService"
            android:enabled="true"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 芒聰聙芒聰聙 茅聳聥忙漏聼氓禄拢忙聮颅忙聨楼忙聰露氓聶篓 芒聰聙芒聰聙 -->
        <receiver
            android:name=".util.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- 芒聰聙芒聰聙 茅聸禄茅聡聫氓禄拢忙聮颅忙聨楼忙聰露氓聶篓 芒聰聙芒聰聙 -->
        <receiver
            android:name=".util.BatteryReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BATTERY_CHANGED" />
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
                <action android:name="android.intent.action.ACTION_POWER_DISCONNECTED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
