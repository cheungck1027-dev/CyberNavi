                    android:layout_height="wrap_content"
                    android:text="ГўВқВҢ Г§В„ВЎГ©ВҡВңГ§ВӨВҷГҰВңВҚГҘВӢВҷГҜВјВҡГ©ВңВҖГЁВҰВҒГ©В–ВӢГҘВ•Вҹ"
