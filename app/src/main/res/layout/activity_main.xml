<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1F33"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- 標題 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ PROJECT CYBER-NAVI"
            android:textColor="#00D4FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="雷霆 AI 領航員"
            android:textColor="#88AABB"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- 整體狀態卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A3A5C"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="檢查中..."
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnStartThunder"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="⚡ 啟動雷霆"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:backgroundTint="#0078D4"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnStopThunder"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="💤 讓雷霆休眠"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp"
                    android:backgroundTint="#2A2A3A" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 權限狀態卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A2A3A"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="權限狀態"
                    android:textColor="#88AABB"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp" />

                <!-- 懸浮視窗權限 -->
                <TextView
                    android:id="@+id/tvOverlayStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="❌ 懸浮視窗權限：需要開啟"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnGrantOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="開啟懸浮視窗權限"
                    android:textSize="13sp"
                    android:backgroundTint="#B8860B"
                    android:layout_marginBottom="20dp" />

                <!-- 無障礙服務 -->
                <TextView
                    android:id="@+id/tvAccessibilityStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="❌ 無障礙服務：需要開啟"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnGrantAccessibility"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="開啟無障礙服務"
                    android:textSize="13sp"
                    android:backgroundTint="#B8860B" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 版本資訊 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v0.1.0-alpha  |  Phase 1 Build"
            android:textColor="#446688"
            android:textSize="11sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
